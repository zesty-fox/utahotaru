{
  "audio": {
    "default_volume": 80,
    "default_speed": 1.0,
    "auto_play_on_load": false
  },
  "timing": {
    "default_check_count": 1,
    "auto_advance_after_tag": true,
    "show_preview_lines": 5,
    "tag_offset_ms": 0,
    "speed_correction": 100,
    "fast_forward_ms": 3000,
    "rewind_ms": 2000,
    "jump_before_ms": 2000,
    "timing_adjust_step_ms": 10,
    "disable_click_jump": false,
    "guide_symbol": "●",
    "guide_count": 1,
    "guide_duration_ms": 1000
  },
  "auto_check": {
    "hiragana": true,
    "katakana": true,
    "kanji": true,
    "alphabet": false,
    "digit": false,
    "symbol": false,
    "space": false,
    "auto_on_load": true,
    "check_n": false,
    "check_sokuon": false,
    "check_parentheses": true,
    "check_empty_lines": false,
    "check_line_start": true,
    "check_line_end": true,
    "space_after_japanese": false,
    "space_after_alphabet": false,
    "space_after_symbol": true,
    "small_kana": false,
    "check_space_as_line_end": true,
    "checkpoint_on_punctuation": false,
    "check_english_word_end": false,
    "delete_ruby_types": [
      "hiragana",
      "symbol",
      "long_vowel",
      "sokuon",
      "other",
      "space"
    ],
    "space_as_line_end": true
  },
  "ui": {
    "theme": "auto",
    "language": "zh_CN",
    "font_size": 18,
    "current_line_font_size": 22,
    "ruby_size": 10,
    "ruby_spacing": 4,
    "cp_size": 8,
    "line_height_factor": 1.2,
    "lyrics_alignment": "left",
    "alignment_margin": 168,
    "checkpoint_markers": {
      "cp_first_timed": "▶",
      "cp_first_empty": "▷",
      "cp_multi_timed": "▮",
      "cp_multi_empty": "▯",
      "cp_sentence_end_timed": "⬟",
      "cp_sentence_end_empty": "⬠"
    }
  },
  "export": {
    "default_format": "Nicokara (带注音)",
    "auto_add_extension": true,
    "last_export_dir": "D:\\",
    "offset_ms": -390,
    "software_compensation_ms": -90,
    "nicokara_pause_char": "^"
  },
  "ruby_split_mode": "mora",
  "ruby_dictionary": {
    "enabled": true
  },
  "dictionary_version": 1,
  "nicokara_tags": {
    "title": "",
    "artist": "",
    "album": "",
    "tagging_by": "",
    "silence_ms": 0,
    "custom": []
  },
  "auto_save": {
    "enabled": true,
    "interval_minutes": 5
  },
  "complete_timestamp": {
    "scope_types": [
      "kanji",
      "hiragana",
      "katakana",
      "sokuon",
      "long_vowel",
      "chisai_kana"
    ],
    "exclude_rules": [
      "linked"
    ]
  },
  "shortcuts": {
    "timing_mode": {
      "play_pause": "D:short",
      "stop": "S:short",
      "tag_now": "SPACE:short",
      "tag_now_extra": "",
      "seek_back": "Z:short",
      "seek_forward": "X:short",
      "speed_down": "Q:short",
      "speed_up": "W:short",
      "edit_ruby": "F2:short",
      "add_checkpoint": ";:short",
      "remove_checkpoint": "':short",
      "volume_up": "CTRL+Q:short",
      "volume_down": "CTRL+W:short",
      "nav_prev_line": "UP:short",
      "nav_next_line": "DOWN:short",
      "nav_prev_char": "LEFT:short",
      "nav_next_char": "RIGHT:short",
      "cycle_checkpoint_prev": "ALT+LEFT:short",
      "toggle_line_end": ".:short",
      "toggle_word_join": "F3:short",
      "timestamp_up": "ALT+UP:short",
      "timestamp_down": "ALT+DOWN:short",
      "cycle_checkpoint": "ALT+RIGHT:short",
      "break_line_here": "Return:short",
      "delete_char": "Delete:short",
      "delete_timestamp": "Backspace:short",
      "bulk_change": "CTRL+H:short",
      "modify_char": "CTRL+Y:short",
      "insert_guide": "CTRL+U:short",
      "modify_line": "CTRL+I:short",
      "analyze_rubies": "CTRL+O:short",
      "delete_rubies_by_type": "CTRL+P:short",
      "set_singer_by_line": "CTRL+L:short",
      "apply_singer": "CTRL+K:short",
      "undo": "CTRL+Z:short",
      "redo": "CTRL+Y:short",
      "save": "CTRL+S:short",
      "paste_lyrics": "CTRL+V:short",
      "timestamps_to_sentence_end": "CTRL+J:short",
      "quick_export": "CTRL+E:short"

    },
