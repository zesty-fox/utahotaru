{
  "audio": {
    "default_volume": 80,
    "default_speed": 1.0,
    "speed_slider_min": 0.2,
    "speed_slider_max": 2.0,
    "auto_play_on_load": false,
    "hq_speed_change": true
  },
  "timing": {
    "default_check_count": 1,
    "auto_advance_after_tag": true,
    "show_preview_lines": 5,
    "tag_offset_ms": 0,
    "speed_correction": 100,
    "fast_forward_ms": 3000,
    "rewind_ms": 2000,
    "jump_before_ms": 2000,
    "timing_adjust_step_ms": 10,
    "disable_click_jump": false,
    "guide_symbol": "●",
    "guide_count": 1,
    "guide_duration_ms": 1000
  },
  "auto_check": {
    "hiragana": true,
    "katakana": true,
    "kanji": true,
    "alphabet": false,
    "digit": true,
    "symbol": false,
    "space": false,
    "auto_on_load": true,
    "romanize_ruby": false,
    "check_n": true,
    "check_sokuon": true,
    "check_long_vowel": false,
    "check_parentheses": true,
    "check_empty_lines": false,
    "check_line_start": true,
    "check_line_end": true,
    "space_after_japanese": true,
    "space_after_alphabet": false,
    "space_after_symbol": true,
    "small_kana": false,
    "check_space_as_line_end": true,
    "checkpoint_on_punctuation": false,
    "check_english_word_end": false,
    "delete_ruby_types": [
      "hiragana",
      "symbol",
      "long_vowel",
      "sokuon",
      "other",
      "space"
    ],
    "space_as_line_end": true,
    "english_syllable_check": true
  },
  "fulltext_editor": {
    "font_size": 12,
    "show_ch_width": true
  },
  "ui": {
    "theme": "auto",
    "language": "zh_CN",
    "font_size": 30,
    "current_line_font_size": 30,
    "ruby_size": 15,
    "ruby_spacing": 4,
    "cp_size": 12,
    "line_height_factor": 1.2,
    "lyrics_alignment": "left",
    "alignment_margin": 168,
    "checkpoint_markers": {
      "cp_first_timed": "▶",
      "cp_first_empty": "▷",
      "cp_multi_timed": "▮",
      "cp_multi_empty": "▯",
      "cp_sentence_end_timed": "●",
      "cp_sentence_end_empty": "○"
    }
  },
  "export": {
    "default_format": "Nicokara (带注音)",
    "auto_add_extension": true,
    "last_export_dir": "D:\\",
    "offset_ms": -230,
    "software_compensation_ms": 0,
    "nicokara_pause_char": "^"
  },
  "ruby_split_mode": "mora",
  "ruby_dictionary": {
    "enabled": true,
    "annotate_katakana_with_english": false
  },
  "dictionary_version": 6,
  "nicokara_tags": {
    "title": "",
    "artist": "",
    "album": "",
    "tagging_by": "",
    "silence_ms": 0,
    "custom": []
  },
  "auto_save": {
    "enabled": true,
    "interval_minutes": 5
  },
  "complete_timestamp": {
    "scope_types": [
      "kanji",
      "hiragana",
      "katakana",
      "sokuon",
      "long_vowel",
      "chon",
      "chisai_kana"
    ],
    "exclude_rules": [
      "linked"
    ]
  },
  "shortcuts": {
    "timing_mode": {
      "play_pause": "D:short",
